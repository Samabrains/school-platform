# Copy to secrets.local.env and fill in your live values.
# Never commit secrets.local.env (it is gitignored).

# --- Auto-generated on first run (init-auth-secrets.mjs) ---
# PLATFORM_API_SECRET=
# PLATFORM_AUTH_SECRET=

# --- Pesapal live ---
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# Filled after: node scripts/register-pesapal-ipn.mjs
PESAPAL_IPN_NOTIFICATION_ID=

# --- Brevo ---
BREVO_API_KEY=

# --- Cloudflare (provisioning + optional) ---
CLOUDFLARE_API_TOKEN=

# IPN callback URL (default: workers.dev until platform.samabrains.com is on CF)
PESAPAL_IPN_URL=https://school-platform.ssebasamatha.workers.dev/webhooks/pesapal/ipn
